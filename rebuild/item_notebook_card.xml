<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <!-- The Custom Solid Color Square Card Container Icon -->
    <FrameLayout
        android:id="@+id/notebookIconCard"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="#CCCCCC">

        <!-- Centered Black Letter 'X' with Contrast White Shield -->
        <TextView
            android:id="@+id/notebookIconText"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:text="X"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/rounded_white_circle_bg"
            android:textSize="14sp"/>
    </FrameLayout>

    <!-- Small Clickable Target Next to the Card to Change its Color Profile -->
    <ImageView
        android:id="@+id/colorSquareTrigger"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:padding="6dp"
        android:src="@android:drawable/ic_menu_manage"
        android:contentDescription="Change Color"
        android:background="?android:attr/selectableItemBackgroundBorderless"/>

    <!-- Notebook Text Title Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/txtNotebookTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notebook Title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000"/>
            
    </LinearLayout>

</LinearLayout>