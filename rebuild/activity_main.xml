<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Scrollable Save Area list of notebooks -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewNotebooks"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnCreateNotebook"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Open New Card Creation Controller Trigger -->
    <Button
        android:id="@+id/btnCreateNotebook"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:text="+ Open New Card"
        android:textSize="16sp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"/>

</RelativeLayout>