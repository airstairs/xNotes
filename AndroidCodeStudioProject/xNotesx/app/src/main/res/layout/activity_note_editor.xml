<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Top Action Toolbar Area -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnToolsMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬛ Tools"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnSizesMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📐 Stroke"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#CCCCCC"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnUndo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↩️ Undo"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnRedo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↪️ Redo"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnZoomReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍 Reset" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Main Active Workspace Canvas Component View -->
    <com.xthan.xnotesx.DrawingCanvasView
        android:id="@+id/drawingCanvas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        android:elevation="2dp"
        android:background="#FFFFFF" />

    <!-- System Control Footer Navigation Deck -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:elevation="8dp">

        <!-- Notebook Title Block Display Left -->
        <TextView
            android:id="@+id/txtBottomNotebookTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerInParent="true"
            android:text="Notebook"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxWidth="140dp"
            android:ellipsize="end"
            android:singleLine="true" />

        <!-- Canvas Operational Commands & Nav Deck Right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnDeletePage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗑️ Delete"
                android:textColor="#FF3B30"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnAddPage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➕ Page"
                android:layout_marginEnd="12dp" />

            <!-- Your requested Page Jump Button inserted right here -->
            <Button
                android:id="@+id/btnJumpPage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📂 Jump"
                android:textSize="14sp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnPrevPage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/txtPageIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginHorizontal="6dp" />

            <Button
                android:id="@+id/btnNextPage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶" />

        </LinearLayout>
    </RelativeLayout>
</LinearLayout>