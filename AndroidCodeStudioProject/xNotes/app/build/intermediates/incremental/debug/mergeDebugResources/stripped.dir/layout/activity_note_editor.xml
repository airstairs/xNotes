<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Compact No-Scroll Main Ribbon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EEEEEE"
        android:padding="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnToolsMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✏️ Tools"
            android:textSize="12sp"
            android:padding="4dp"/>

        <Button
            android:id="@+id/btnSizesMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📐 Size"
            android:textSize="12sp"
            android:padding="4dp"
            android:layout_marginStart="4dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#999999"
            android:layout_marginHorizontal="6dp"/>

        <Button
            android:id="@+id/btnPrevPage"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="&lt;"
            android:padding="0dp"/>

        <TextView
            android:id="@+id/txtPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="6dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnNextPage"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="&gt;"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnAddPage"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="+"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:layout_marginStart="4dp"/>

        <Button
            android:id="@+id/btnDeletePage"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="🗑️"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <com.xthan.xnotes.DrawingCanvasView
        android:id="@+id/drawingCanvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF" />
        
</LinearLayout>