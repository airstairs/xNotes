<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Compact Top Toolbar Ribbon -->
    <LinearLayout
        android:id="@+id/topToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#EEEEEE"
        android:padding="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnToolsMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tools"
            android:textSize="12sp"
            android:padding="4dp"/>

        <Button
            android:id="@+id/btnSizesMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Size"
            android:textSize="12sp"
            android:padding="4dp"
            android:layout_marginStart="4dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#999999"
            android:layout_marginHorizontal="6dp"/>

        <Button
            android:id="@+id/btnPrevPage"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="◀"
            android:padding="0dp"/>

        <TextView
            android:id="@+id/txtPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="6dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnNextPage"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="▶"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnAddPage"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="+"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:layout_marginStart="4dp"/>

        <Button
            android:id="@+id/btnDeletePage"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="DEL"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <!-- Main Workspace Drawing Canvas (Fixed to clear bottom buttons) -->
    <com.xthan.xnotes.DrawingCanvasView
        android:id="@+id/drawingCanvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topToolbar"
        android:layout_above="@+id/bottomControllerLayer"
        android:background="#FFFFFF" />

    <!-- Clean Bottom Row Controller Layer -->
    <RelativeLayout
        android:id="@+id/bottomControllerLayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp">

        <!-- Floating Left Zoom Reset Action Target -->
        <Button
            android:id="@+id/btnZoomReset"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_alignParentStart="true"
            android:text="Zoom Out"
            android:textSize="11sp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:paddingHorizontal="12dp" />

        <!-- Centered Notebook Title Indicator -->
        <TextView
            android:id="@+id/txtBottomNotebookTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Notebook Name"
            android:textColor="#777777"
            android:textSize="12sp"
            android:textStyle="italic"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingHorizontal="60dp" />

        <!-- Floating Undo/Redo Controls Layer (Far Right Edge) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnUndo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:text="Undo"
                android:textSize="12sp"
                android:backgroundTint="#FFFFFF"
                android:textColor="#000000" />

            <Button
                android:id="@+id/btnRedo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="Redo"
                android:textSize="12sp"
                android:backgroundTint="#FFFFFF"
                android:textColor="#000000" />
                
        </LinearLayout>
        
    </RelativeLayout>
    
</RelativeLayout>