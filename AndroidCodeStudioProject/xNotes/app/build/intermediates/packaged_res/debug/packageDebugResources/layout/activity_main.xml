<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- xNotes Header Title Label -->
    <TextView
        android:id="@+id/txtHeaderLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:text="xNotes"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#333333"/>

    <!-- Global Actions Bar (Import, Export, Enter Selection Mode) -->
    <LinearLayout
        android:id="@+id/migrationActionBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnImportBackup"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Import"
            android:textSize="11sp"
            android:backgroundTint="#607D8B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnExportBackup"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginStart="4dp"
            android:text="Export"
            android:textSize="11sp"
            android:backgroundTint="#607D8B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnManageThreads"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginStart="4dp"
            android:text="Delete Threads"
            android:textSize="11sp"
            android:backgroundTint="#E91E63"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- Contextual Selection Sub-Menu (Hidden by default, shows up when managing threads) -->
    <LinearLayout
        android:id="@+id/selectionContextBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/txtHeaderLabel"
        android:background="#EEEEEE"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btnSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Select All"
            android:textSize="11sp"
            android:backgroundTint="#78909C"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btnCancelSelection"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Cancel"
            android:textSize="11sp"
            android:backgroundTint="#9E9E9E"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnConfirmMassDelete"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:text="Delete Selected"
            android:textSize="11sp"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Scrollable Save Stack -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewNotebooks"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/selectionContextBar"
        android:layout_above="@id/btnCreateNotebook"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Add Controller Button Trigger -->
    <Button
        android:id="@+id/btnCreateNotebook"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:text="+ Open New Card"
        android:textSize="16sp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"/>

</RelativeLayout>