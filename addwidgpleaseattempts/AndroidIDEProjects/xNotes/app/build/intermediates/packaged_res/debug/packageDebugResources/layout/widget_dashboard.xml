<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background_semi_transparent"
    android:padding="16dp">

    <!-- Header Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="xNotes"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"/>

    <!-- Create New Notebook Action Button -->
    <Button
        android:id="@+id/widget_btn_create"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Create New Notebook"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"/>

    <!-- Scrollable container area for existing note entries -->
    <!--
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp">
        <LinearLayout
            android:id="@+id/widget_saves_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
    
-->
    
    <ListView
        android:id="@+id/widget_notebook_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp" />


    <!-- Bottom Actions Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/widget_btn_export"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Export"
            android:textSize="10sp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="2dp"/>

        <Button
            android:id="@+id/widget_btn_import"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Import"
            android:textSize="10sp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="2dp"/>

        <Button
            android:id="@+id/widget_btn_delete"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Delete"
            android:textSize="10sp"
            android:backgroundTint="#E91E63"
            android:textColor="#FFFFFF"/>
    </LinearLayout>
</LinearLayout>